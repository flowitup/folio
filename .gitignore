# Defense-in-depth: never commit env files at the parent level.
# Submodules (folio-back-end, folio-front-end) have their own .gitignore
# entries; this catches anything that lands in the parent root by mistake.
.env
.env.*

# macOS noise
.DS_Store

# Claude Code / agent artifacts
.claude/
plans/

# Agent-generated feature artifacts
.feature-screenshots/
FEATURES.md

# Agent scratch and generated docs (keep only human-authored core docs)
docs/CLAUDE.md
docs/ai/
docs/checklist/
docs/guide/
docs/plans/
docs/journals/
docs/state/
docs/tmp/
docs/codebase-summary.md
docs/design-guidelines.md
docs/project-roadmap.md
docs/security-checklist.md
